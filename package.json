{
	"name": "electrobun-vue",
	"version": "1.0.0",
	"type": "module",
	"description": "Electrobun app with Vue and Vite HMR",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"clean:build": "rm -rf artifacts build dist",
		"build:stable": "bun run clean:build && vite build && electrobun build --env=stable",
		"build:canary": "bun run clean:build && vite build && electrobun build --env=canary",
		"lint": "biome check . && eslint . --ext .vue",
		"lint:fix": "biome check . --write && eslint . --ext .vue --fix",
		"typecheck": "vue-tsc --noEmit",
		"release": "bun run scripts/release.ts"
	},
	"dependencies": {
		"@inquirer/confirm": "^6.0.10",
		"@inquirer/select": "^5.1.2",
		"electrobun": "1.16.0",
		"pinia": "^3.0.4",
		"vue-router": "^5.0.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "latest",
		"@vitejs/plugin-vue": "^5.2.1",
		"concurrently": "^9.1.0",
		"eslint-plugin-vue": "^10.8.0",
		"jiti": "^2.6.1",
		"less": "^4.6.4",
		"sharp": "^0.34.5",
		"typescript": "^5.7.2",
		"typescript-eslint": "^8.57.1",
		"vite": "^6.0.3",
		"vue": "^3.5.13",
		"vue-tsc": "^2.2.0"
	}
}
